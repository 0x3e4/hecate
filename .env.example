# ─── Backend ──────────────────────────────────────────────────────────────────
# Deployment label (production | development); affects logging only.
ENVIRONMENT=production
# URL prefix for all REST endpoints; the frontend hard-codes /api, so don't change.
API_PREFIX=/api/v1
# Public-facing host; used in CORS, OAuth callbacks, badge links.
DOMAIN=hecate.pw
# Python log level: DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL=INFO
# Optional: gate the /system page behind a shared password.
SYSTEM_PASSWORD=

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Connection string (no auth in URI when using MONGO_USERNAME / MONGO_PASSWORD).
MONGO_URL=mongodb://mongo:27017
MONGO_USERNAME=hecate
MONGO_PASSWORD=***REMOVED-OPENSEARCH-PASSWORD***
# TLS to MongoDB; pair with MONGO_TLS_CERT_KEY_FILE for client-cert auth.
MONGO_TLS=false
MONGO_TLS_CERT_KEY_FILE=
# Database name.
MONGO_DB=hecate
# Collection names — override only when sharing a database with another tool.
MONGO_VULNERABILITIES_COLLECTION=vulnerabilities
MONGO_CPE_COLLECTION=cpe_catalog
MONGO_ASSET_VENDORS_COLLECTION=asset_vendors
MONGO_ASSET_PRODUCTS_COLLECTION=asset_products
MONGO_ASSET_VERSIONS_COLLECTION=asset_versions
MONGO_INGESTION_STATE_COLLECTION=ingestion_state
MONGO_INGESTION_LOG_COLLECTION=ingestion_logs
MONGO_KEV_COLLECTION=known_exploited_vulnerabilities
MONGO_CWE_COLLECTION=cwe_catalog
MONGO_SCAN_TARGETS_COLLECTION=scan_targets
MONGO_SCANS_COLLECTION=scans
MONGO_SCAN_FINDINGS_COLLECTION=scan_findings
MONGO_SCAN_SBOM_COLLECTION=scan_sbom_components
MONGO_NOTIFICATION_RULES_COLLECTION=notification_rules
MONGO_NOTIFICATION_CHANNELS_COLLECTION=notification_channels

# ─── OpenSearch ───────────────────────────────────────────────────────────────
# Cluster URL (the Hecate compose file ships with TLS and a self-signed cert).
OPENSEARCH_URL=https://opensearch:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=***REMOVED-OPENSEARCH-PASSWORD***
# Vulnerabilities index name.
OPENSEARCH_INDEX=hecate-vulnerabilities
# Mapping ceiling — raise if you add many custom analyser fields.
OPENSEARCH_INDEX_TOTAL_FIELDS_LIMIT=2000
# from+size ceiling for paged search; the UI never asks for more than this.
OPENSEARCH_INDEX_MAX_RESULT_WINDOW=200000
# Set true once you have a properly issued cert chain on the cluster.
OPENSEARCH_VERIFY_CERTS=false
# Path inside the backend container to a PEM CA bundle used to verify the cluster.
# OPENSEARCH_CA_CERT=/path/to/ca.pem
# Heap sizing for the OpenSearch container (compose passes this through as ES_JAVA_OPTS).
OPENSEARCH_JAVA_OPTS=-Xms2g -Xmx2g

# ─── Trust store ──────────────────────────────────────────────────────────────
# Path inside both backend & scanner containers to a PEM with your corporate /
# MITM-proxy root CA. The startup hook MERGES it with the system CAs, so include
# only your own roots — Mozilla roots come from the container.
# HTTP_CA_BUNDLE=/etc/ssl/custom-ca.pem

# ─── AI providers (all optional — each one activates when its API key is set) ─
# OpenAI Responses API (reasoning + web search).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OpenAI reasoning effort: minimal | low | medium | high.
OPENAI_REASONING_EFFORT=medium
# Hard ceiling for any single AI completion across providers.
AI_MAX_OUTPUT_TOKENS=16000
# Anthropic Messages API.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-haiku-20240307
# Google Gemini via google-genai SDK.
GOOGLE_GEMINI_API_KEY=
GOOGLE_GEMINI_MODEL=gemini-1.5-flash
# Default response language for AI prompts: en | de.
AI_RESPONSE_LANGUAGE=en
# Toggles web search where the provider supports it (OpenAI, OpenRouter `:online`).
AI_WEB_SEARCH_ENABLED=true
# Optional gate on the AI Analyse page; users must enter this before seeing it.
AI_ANALYSIS_PASSWORD=

# OpenAI-compatible endpoints (Ollama / vLLM / OpenRouter / LocalAI / LM Studio).
# Activates when BASE_URL and MODEL are both set; API key is optional.
# OPENAI_COMPATIBLE_BASE_URL=http://ollama:11434/v1         # Ollama
# OPENAI_COMPATIBLE_BASE_URL=http://vllm:8000/v1            # vLLM
# OPENAI_COMPATIBLE_BASE_URL=https://openrouter.ai/api/v1   # OpenRouter
# OPENAI_COMPATIBLE_API_KEY=
# OPENAI_COMPATIBLE_MODEL=llama3.1:latest
# OPENAI_COMPATIBLE_LABEL=Ollama (local)

# ─── MCP Server (Model Context Protocol) ──────────────────────────────────────
# Auth is delegated to an upstream OAuth IdP. Register the OAuth app with
# redirect URI: https://<your-host>/mcp/oauth/idp/callback
# Mount the /mcp endpoint on/off.
MCP_ENABLED=false
# Provider: github | microsoft | oidc.
MCP_OAUTH_PROVIDER=
MCP_OAUTH_CLIENT_ID=
MCP_OAUTH_CLIENT_SECRET=
# Microsoft: https://login.microsoftonline.com/<tenant>/v2.0
# OIDC:      https://your-idp.example/application/o/hecate
# GitHub:    leave empty
MCP_OAUTH_ISSUER=
# Optional: override default IdP scopes (space-separated).
MCP_OAUTH_SCOPES=
# CSV of IPs / CIDRs allowed to call write tools (trigger_scan, save_*).
# Empty = no client gets the mcp:write scope.
MCP_WRITE_IP_SAFELIST=
# Optional CSV allowlist of identities / emails (defence-in-depth on top of IdP).
MCP_ALLOWED_USERS=
# Per-client request budget.
MCP_RATE_LIMIT_PER_MINUTE=60
# Max rows any single MCP tool returns.
MCP_MAX_RESULTS=50
# Cap on simultaneous MCP connections.
MCP_MAX_CONCURRENT_CONNECTIONS=20
# Pin the base URL advertised in OAuth metadata when reverse proxies don't
# forward Host / X-Forwarded-Host reliably (e.g. https://sec.example.org).
MCP_PUBLIC_URL=
# DEV ONLY: bypass OAuth entirely; grants every request mcp:read+mcp:write.
MCP_AUTH_DISABLED=false

# ─── Ingestion: EUVD (ENISA) ──────────────────────────────────────────────────
EUVD_BASE_URL=https://euvdservices.enisa.europa.eu/api
EUVD_TIMEOUT_SECONDS=30
# Per-page record count; EUVD allows up to 250.
EUVD_PAGE_SIZE=250
# Min seconds between requests (client-side rate limit).
EUVD_RATE_LIMIT_SECONDS=1.0
# Cap per scheduled run; 0/empty = unbounded.
EUVD_MAX_RECORDS_PER_RUN=2000
# Optional ISO date that the very first incremental sync starts from.
VULNERABILITY_INITIAL_BACKFILL_SINCE=

# ─── Ingestion: NVD (NIST) ────────────────────────────────────────────────────
NVD_BASE_URL=https://services.nvd.nist.gov/rest/json
# Optional API key (5x rate-limit increase).
NVD_API_KEY=
NVD_TIMEOUT_SECONDS=60
NVD_RATE_LIMIT_SECONDS=0.6
# Max NVD page size; do not lower or backfill takes much longer.
NVD_PAGE_SIZE=2000
# Retries on transient HTTP / decode errors before failing hard.
NVD_MAX_RETRIES=5
# Exponential backoff base in seconds.
NVD_RETRY_BACKOFF_SECONDS=5.0

# ─── Ingestion: CPE (NVD) ─────────────────────────────────────────────────────
CPE_BASE_URL=https://services.nvd.nist.gov/rest/json/cpes/2.0
# Cap per scheduled run; 0/empty = unbounded.
CPE_MAX_RECORDS_PER_RUN=20000

# ─── Ingestion: KEV (CISA) ────────────────────────────────────────────────────
KEV_FEED_URL=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json

# ─── Ingestion: CWE (MITRE) ───────────────────────────────────────────────────
CWE_BASE_URL=https://cwe-api.mitre.org/api/v1
CWE_TIMEOUT_SECONDS=30
CWE_RATE_LIMIT_SECONDS=1.0

# ─── Ingestion: CAPEC (MITRE) ─────────────────────────────────────────────────
CAPEC_XML_URL=https://capec.mitre.org/data/xml/capec_latest.xml
CAPEC_TIMEOUT_SECONDS=60

# ─── Ingestion: CIRCL ─────────────────────────────────────────────────────────
CIRCL_BASE_URL=https://vulnerability.circl.lu/api
CIRCL_TIMEOUT_SECONDS=30
CIRCL_RATE_LIMIT_SECONDS=0.5
CIRCL_MAX_RETRIES=3
CIRCL_RETRY_BACKOFF_SECONDS=3.0
# Per-run cap on EPSS-enrichment lookups.
CIRCL_MAX_RECORDS_PER_RUN=200

# ─── Ingestion: GHSA (GitHub Advisory) ────────────────────────────────────────
GHSA_BASE_URL=https://api.github.com/advisories
# Optional GitHub PAT — strongly recommended (60→5000 req/h).
GHSA_TOKEN=
GHSA_TIMEOUT_SECONDS=30
GHSA_RATE_LIMIT_SECONDS=1.0
GHSA_MAX_RETRIES=3
GHSA_RETRY_BACKOFF_SECONDS=5.0
GHSA_MAX_RECORDS_PER_RUN=5000

# ─── Ingestion: OSV.dev ───────────────────────────────────────────────────────
OSV_BASE_URL=https://api.osv.dev/v1
OSV_TIMEOUT_SECONDS=30
OSV_RATE_LIMIT_SECONDS=0.5
OSV_MAX_RETRIES=5
OSV_RETRY_BACKOFF_SECONDS=5.0
# Per-run cap; empty = unbounded (recommended — the timeout below is the real bound).
OSV_MAX_RECORDS_PER_RUN=
# Initial-sync parallelism: workers × batch size in flight at any time.
OSV_INITIAL_SYNC_CONCURRENCY=16
OSV_INITIAL_SYNC_BATCH_SIZE=32

# ─── Ingestion: deps.dev (MAL-* version enrichment) ───────────────────────────
DEPS_DEV_BASE_URL=https://api.deps.dev/v3
DEPS_DEV_TIMEOUT_SECONDS=15
DEPS_DEV_RATE_LIMIT_SECONDS=0.1
DEPS_DEV_MAX_RETRIES=3
DEPS_DEV_RETRY_BACKOFF_SECONDS=2.0

# ─── Ingestion: shared ────────────────────────────────────────────────────────
# Sent as User-Agent on every outbound ingestion call.
INGESTION_USER_AGENT=hecate-ingestion/1.0
# Wall-clock budget per ingestion run (minutes); 0 = no timeout.
INGESTION_RUNNING_TIMEOUT_MINUTES=0
# Run a one-shot sync of every empty source at backend startup.
INGESTION_BOOTSTRAP_ON_STARTUP=true
# Which source wins on overlapping vulnerable-version fields: NVD | EUVD.
INGESTION_PRIORITY_VULN_DB=NVD

# ─── Scheduler ────────────────────────────────────────────────────────────────
# Disables every periodic ingestion job when false.
SCHEDULER_ENABLED=true
# IANA TZ for cron expressions.
SCHEDULER_TIMEZONE=UTC
# Per-source incremental intervals (minutes).
SCHEDULER_EUVD_INTERVAL_MINUTES=10
SCHEDULER_CPE_INTERVAL_MINUTES=1440
SCHEDULER_NVD_INTERVAL_MINUTES=10
SCHEDULER_KEV_INTERVAL_MINUTES=60
# CWE / CAPEC use wall-clock cron (Mon/Tue 03:00); these are stale-catchup thresholds.
SCHEDULER_CWE_INTERVAL_DAYS=7
SCHEDULER_CAPEC_INTERVAL_DAYS=7
SCHEDULER_CIRCL_INTERVAL_MINUTES=5
SCHEDULER_GHSA_INTERVAL_MINUTES=30
SCHEDULER_OSV_INTERVAL_MINUTES=30
# Weekly full-sync runs (heal drift from incremental cap-on-cursor).
SCHEDULER_EUVD_FULL_SYNC_ENABLED=true
SCHEDULER_EUVD_FULL_SYNC_CRON_HOUR=1
SCHEDULER_EUVD_FULL_SYNC_CRON_DAY_OF_WEEK=sat
SCHEDULER_NVD_FULL_SYNC_ENABLED=true
SCHEDULER_NVD_FULL_SYNC_CRON_HOUR=1
SCHEDULER_NVD_FULL_SYNC_CRON_DAY_OF_WEEK=sat
SCHEDULER_OSV_FULL_SYNC_ENABLED=true
SCHEDULER_OSV_FULL_SYNC_CRON_HOUR=1
SCHEDULER_OSV_FULL_SYNC_CRON_DAY_OF_WEEK=fri

# ─── SCA scanning ─────────────────────────────────────────────────────────────
# Mounts the /scans pages and SCA endpoints when true.
SCA_ENABLED=true
# Scanner sidecar URL (compose service name + port).
SCA_SCANNER_URL=http://scanner:8080
# Backend → sidecar HTTP read timeout. MUST stay above the largest scanner
# subprocess timeout (currently DEVSKIM_TIMEOUT_SECONDS=1500), otherwise the
# structured timeout error is replaced by a bare "scanner: " banner because
# httpx.ReadTimeout stringifies to "".
SCA_SCANNER_TIMEOUT_SECONDS=1560
# Hard cap on uploaded source archives.
SCA_SOURCE_ARCHIVE_MAX_BYTES=52428800
# How often auto-scan checks each target for changes.
SCA_AUTO_SCAN_INTERVAL_MINUTES=1440
# Concurrent scan slots (semaphore).
SCA_MAX_CONCURRENT_SCANS=2
# Pre-scan resource gates against the sidecar's /stats.
SCA_MIN_FREE_MEMORY_MB=1024
SCA_MIN_FREE_DISK_MB=2048
# Master toggle for auto-scanning of registered targets.
SCA_AUTO_SCAN_ENABLED=false

# Shared key for CI/CD scan submissions: POST {DOMAIN}{API_PREFIX}/scans (X-API-Key).
SCA_API_KEY=

# Per-host registry / git auth used by the scanner sidecar.
# Format: host:token (Git PATs) or host:user:token (Docker Hub).
SCANNER_AUTH=

# Scanner cache directories on the sidecar's tmpfs.
TRIVY_CACHE_DIR=/tmp/.trivy-cache
GRYPE_DB_CACHE_DIR=/tmp/.grype-cache

# Semgrep ruleset (see https://semgrep.dev/explore).
SEMGREP_RULES=p/security-audit

# Per-scanner subprocess timeout overrides (seconds). Unset = scanner default.
# DevSkim default 1500 — Microsoft's SAST walker is slow on big .NET trees.
DEVSKIM_TIMEOUT_SECONDS=1500

# Comma-separated package names to skip during malware detection.
HECATE_MALWARE_ALLOWLIST=
# How long the typosquatting check caches registry lookups (seconds; 7 d default).
HECATE_REGISTRY_CACHE_TTL=604800

# ─── Trusted proxy (real-IP extraction) ───────────────────────────────────────
# CSV of proxy IPs whose forwarded headers we trust.
TRUSTED_PROXY_IPS=10.0.0.5,10.0.0.6
# Header carrying the original chain of client IPs.
TRUSTED_PROXY_FORWARD_HEADER=x-forwarded-for
# Header carrying the originating client IP (preferred over the chain).
TRUSTED_PROXY_REAL_IP_HEADER=x-real-ip

# ─── Notifications (Apprise) ──────────────────────────────────────────────────
# Master toggle; rules and channels are inert when false.
NOTIFICATIONS_ENABLED=false
# Apprise REST API base URL (compose ships an internal sidecar).
NOTIFICATIONS_APPRISE_URL=http://apprise:8000
# Default Apprise tag routing for notifications.
NOTIFICATIONS_APPRISE_TAGS=all
NOTIFICATIONS_APPRISE_TIMEOUT=10
# Max matches a single watch-rule evaluation may emit per pass.
NOTIFICATIONS_WATCH_RULE_LIMIT=100

# ─── Misc ─────────────────────────────────────────────────────────────────────
# Show the in-app Support page (Ko-fi donate, GitHub star, version-update hint).
SUPPORT_PAGE_ENABLED=true

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Baked into the bundle at build time. The default `/api` works for the standard
# compose setup; only override when the frontend is built standalone.
VITE_API_BASE_URL=/api
